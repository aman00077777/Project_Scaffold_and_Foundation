[MAIN]
load-plugins =
    pylint.extensions.docparams

ignore-patterns =
    test_.*\.py

jobs = 0

[MESSAGES CONTROL]
disable =
    C0114,  ; missing-module-docstring (covered by flake8-docstrings)
    C0115,  ; missing-class-docstring
    C0116,  ; missing-function-docstring
    R0903,  ; too-few-public-methods
    R0801,  ; duplicate-code
    W0511,  ; fixme / todo comments
    E1101,  ; module-has-no-member (false positives with torch)
    W0223,  ; abstract-method not overridden (common in base classes)

[FORMAT]
max-line-length = 88
expected-line-ending-format = LF

[BASIC]
good-names =
    i, j, k, v, e, x, f,
    fn, ax, lr, mt, fh,
    _

[DESIGN]
max-args = 8
max-locals = 20
max-returns = 6
max-branches = 12

[SIMILARITIES]
min-similarity-lines = 6

[TYPECHECK]
ignored-modules =
    torch,
    torch.nn,
    torch.cuda,
    numpy,
    yaml
