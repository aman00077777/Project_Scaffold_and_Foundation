# ──────────────────────────────────────────────────
# .editorconfig — Fusion project editor settings
# https://editorconfig.org
# ──────────────────────────────────────────────────

root = true

# ───── Global defaults ─────
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# ───── Python (matches Black line-length = 88) ─────
[*.py]
indent_size = 4
max_line_length = 88

# ───── YAML / TOML / JSON config files ─────
[*.{yml,yaml,toml,json}]
indent_size = 2

# ───── Markdown ─────
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# ───── INI-style configs (.cfg, .ini, .flake8, .pylintrc, .coveragerc) ─────
[*.{cfg,ini,flake8,pylintrc,coveragerc}]
indent_size = 4

# ───── Makefile (requires tabs) ─────
[Makefile]
indent_style = tab

# ───── Shell scripts ─────
[*.{sh,bash}]
indent_size = 2

# ───── Requirements files ─────
[requirements*.txt]
insert_final_newline = true
