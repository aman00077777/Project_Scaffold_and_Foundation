# ──────────────────────────────────────────────────
# .gitignore — Fusion (Python / PyTorch project)
# ──────────────────────────────────────────────────

# ───── Python bytecode & caches ─────
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ───── Distribution & packaging ─────
build/
dist/
*.egg-info/
*.egg
*.whl
sdist/
eggs/
.eggs/

# ───── Virtual environments ─────
.venv/
venv/
env/
ENV/

# ───── Testing & coverage ─────
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
*.coveragerc.bak
.pytest_cache/
pytest-report.xml
nosetests.xml

# ───── Type checking & linting ─────
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.ruff_cache/

# ───── Jupyter Notebooks ─────
.ipynb_checkpoints/

# ───── IDE & editor files ─────
.idea/
.vscode/
*.swp
*.swo
*~
*.bak
*.orig
*.sublime-project
*.sublime-workspace

# ───── OS-generated files ─────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ───── ML / Deep Learning artifacts ─────
*.pt
*.pth
*.onnx
*.ckpt
*.safetensors
checkpoints/
runs/
logs/
wandb/
mlruns/
tensorboard/

# ───── Data & model caches ─────
data/
*.h5
*.hdf5
*.npz
*.npy
*.pkl
*.pickle

# ───── Miscellaneous ─────
*.log
*.pid
*.seed
*.bak
.env
.env.*
